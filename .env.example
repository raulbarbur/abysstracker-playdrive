# SUPABASE CONFIGURATION
# Found in Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CLOUDFLARE R2 CONFIGURATION (Storage)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-your-id.r2.dev

# AUTHENTICATION
# Minimum 64 characters for security
JWT_SECRET=your-super-long-jwt-secret-key-2026

# APP CONFIG
NEXT_PUBLIC_APP_URL=http://localhost:3000